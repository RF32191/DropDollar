# ===================================
# TAX SYSTEM ENVIRONMENT VARIABLES
# ===================================
# 
# Copy these to your .env.local file and fill in with your actual values
# NEVER commit .env.local to version control
#

# ===================================
# PAYER INFORMATION (YOUR COMPANY)
# ===================================
# TODO: Replace ALL of these with your actual company information

# Your company's Employer Identification Number (9 digits)
# Format: XX-XXXXXXX
TAX_PAYER_EIN=12-3456789

# Your company's legal name (as registered with IRS)
NEXT_PUBLIC_COMPANY_LEGAL_NAME=DropaDollar, Inc.

# Your company's physical address
TAX_PAYER_ADDRESS_LINE1=123 Main Street, Suite 100
TAX_PAYER_ADDRESS_LINE2=
TAX_PAYER_CITY=San Francisco
TAX_PAYER_STATE=CA
TAX_PAYER_POSTAL_CODE=94102

# Contact information
TAX_PAYER_PHONE=(555) 123-4567
TAX_CONTACT_EMAIL=tax@dropadollar.com

# ===================================
# 1099 GENERATION SETTINGS
# ===================================

# Enable/disable 1099 generation (set to 'false' during testing)
TAX_1099_GENERATION_ENABLED=true

# Auto-send 1099s via email (set to 'false' until tested)
TAX_AUTO_SEND_1099=false

# ===================================
# EMAIL CONFIGURATION
# ===================================

# Email sender information
TAX_EMAIL_FROM_NAME=DropaDollar Tax Team
TAX_EMAIL_FROM=tax@dropadollar.com

# Email Provider API Keys (choose one based on your provider)
# Resend (recommended): https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# SendGrid: https://sendgrid.com
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Postmark: https://postmarkapp.com
# POSTMARK_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# AWS SES
# AWS_SES_ACCESS_KEY_ID=AKIAxxxxxxxxxxxx
# AWS_SES_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# AWS_SES_REGION=us-east-1

# ===================================
# ADMIN API SECURITY
# ===================================

# API key for admin endpoints (generate a secure random string)
# Use: openssl rand -base64 32
ADMIN_API_KEY=your-secure-random-key-here-replace-me

# ===================================
# OPTIONAL SETTINGS
# ===================================

# Tax year for testing (defaults to current year - 1)
# TAX_TEST_YEAR=2024

# Minimum payout amount in cents (default: 500 = $5.00)
# MIN_PAYOUT_CENTS=500

# IRS reporting threshold in cents (default: 60000 = $600.00)
# DO NOT CHANGE unless IRS regulations change
# TAX_REPORTING_THRESHOLD_CENTS=60000

